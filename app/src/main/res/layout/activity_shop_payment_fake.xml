<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A1C"
    android:fillViewport="true"
    tools:context=".shop.ShopPaymentFakeActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Эквайринг (демо)"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Настоящие данные карты не вводите. Это макет без реальной оплаты."
            android:textColor="#AAAAAA"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/payment_amount_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:fontFamily="@font/sfprodisplay1semibold"
            android:textColor="@color/white"
            android:textSize="20sp"
            tools:text="К оплате: 4 200 ₽" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:hint="Номер карты"
            app:hintTextColor="#CCCCCC"
            app:placeholderText="1111 1111 1111 1111"
            app:placeholderTextColor="#66FFFFFF">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/input_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text|textNoSuggestions"
                android:maxLength="19"
                android:textColor="@color/white" />
        </com.google.android.material.textfield.TextInputLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:hint="Срок (ММ/ГГ)"
                app:hintTextColor="#CCCCCC"
                app:placeholderText="12/26"
                app:placeholderTextColor="#66FFFFFF">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/input_expiry"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text|textNoSuggestions"
                    android:maxLength="5"
                    android:textColor="@color/white" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_weight="1"
                android:hint="CVC"
                app:hintTextColor="#CCCCCC"
                app:placeholderText="***"
                app:placeholderTextColor="#66FFFFFF">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/input_cvc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:maxLength="3"
                    android:textColor="@color/white" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_pay_fake"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="28dp"
            android:text="Оплатить"
            android:textAllCaps="false"
            app:backgroundTint="@color/orange"
            app:cornerRadius="14dp" />
    </LinearLayout>
</ScrollView>
