<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingBottom="8dp">

    <!-- Таймлайн -->
    <FrameLayout
        android:layout_width="28dp"
        android:layout_height="match_parent"
        android:layout_marginEnd="10dp">

        <View
            android:id="@+id/stop_timeline_line"
            android:layout_width="2dp"
            android:layout_height="match_parent"
            android:layout_gravity="center_horizontal"
            android:background="#55FFFFFF" />

        <View
            android:id="@+id/stop_timeline_dot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="18dp"
            android:background="@drawable/route_itinerary_timeline_dot" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/stop_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <TextView
                android:id="@+id/stop_order"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:fontFamily="@font/sfprodisplay1semibold"
                android:textColor="#99FFFFFF"
                android:textSize="14sp"
                tools:text="1" />

            <TextView
                android:id="@+id/stop_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/sfprodisplay1semibold"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                tools:text="Ижевский пруд" />

            <ImageView
                android:id="@+id/stop_expand_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@string/cd_expand_stop"
                android:src="@drawable/ic_arrow_right"
                android:tint="#CCFFFFFF" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/stop_expanded"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            tools:visibility="visible">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/stop_image"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginTop="4dp"
                android:contentDescription="@string/cd_stop_photo"
                android:scaleType="centerCrop"
                app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.RouteStopPhoto" />

            <TextView
                android:id="@+id/stop_address"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textColor="#BBBBBB"
                android:textSize="13sp"
                android:visibility="gone"
                tools:text="ул. Примерная, 1"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/stop_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:lineSpacingExtra="4dp"
                android:textColor="#E6FFFFFF"
                android:textSize="15sp"
                tools:text="Описание точки маршрута…" />

            <!-- Аудиогид -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/stop_audio_btn"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/route_audio_circle_bg"
                    android:contentDescription="@string/cd_route_audio"
                    android:padding="12dp"
                    android:src="@drawable/ic_play_filled" />

                <com.example.main_screen.ui.EqualizerBarsView
                    android:id="@+id/stop_equalizer"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:alpha="0.85" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/stop_gift_btn"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:minHeight="52dp"
                android:text="@string/route_gift_get"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:visibility="gone"
                app:backgroundTint="#EF4444"
                app:cornerRadius="12dp"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/stop_gift_used"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="#22FFFFFF"
                android:padding="12dp"
                android:text="@string/route_gift_used"
                android:textColor="#AAAAAA"
                android:textSize="14sp"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
